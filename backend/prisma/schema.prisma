generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  password          String
  name              String
  role              String             @default("USER")
  isOnline          Boolean            @default(false)
  lastSeen          DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  profile           Profile?
  posts             Post[]
  comments          Comment[]
  requests          Request[]
  requestReplies    RequestReply[]
  messages          Message[]
  ownedDealRooms    DealRoom[]         @relation("DealRoomOwner")
  invitedDealRooms  DealRoom[]         @relation("DealRoomInvited")
  dealMessages      DealRoomMessage[]
  dealTasks         DealRoomTask[]
  dealMeetings      DealRoomMeeting[]
  groupMemberships  GroupMember[]
  groupPosts        GroupPost[]
  groupMessages     GroupMessage[]
  notifications     Notification[]
  savedPosts        SavedPost[]
  following         UserConnection[]  @relation("UserFollowing")
  followers         UserConnection[]  @relation("UserFollowers")
  conversationsA    Conversation[]     @relation("ConversationA")
  conversationsB    Conversation[]     @relation("ConversationB")
}

model Profile {
  id                  String      @id @default(cuid())
  userId              String      @unique
  accountType         String      @default("PROFESSIONAL")
  company             String?
  location            String?
  bio                 String?
  phone               String?
  whatsapp            String?
  email               String?
  website             String?
  socialLinks         String?
  profilePhoto        String?
  coverPhoto          String?
  rating              Float       @default(4.8)
  reputation          Int         @default(92)
  closedDeals         Int         @default(0)
  averageResponseTime String      @default("38 min")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id           String       @id @default(cuid())
  type         String
  title        String
  description  String
  location     String?
  price        Float?
  propertyType String?
  businessType String?
  bedrooms     Int?
  bathrooms    Int?
  images       String?
  authorId     String
  requestId    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments     Comment[]
  savedBy      SavedPost[]
  request      Request?     @relation(fields: [requestId], references: [id], onDelete: SetNull)
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model UserConnection {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Request {
  id                String        @id @default(cuid())
  businessType      String
  propertyType      String
  location          String
  budgetMin         Float?
  budgetMax         Float?
  bedrooms          Int?
  bathrooms         Int?
  urgency           String        @default("MEDIUM")
  description       String
  clientValidated   Boolean       @default(false)
  contactPreference String?
  attachments       String?
  authorId          String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  author            User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies           RequestReply[]
  posts             Post[]
  dealRooms         DealRoom[]
}

model RequestReply {
  id        String   @id @default(cuid())
  requestId String
  authorId  String
  postId    String?
  message   String
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Conversation {
  id              String    @id @default(cuid())
  userAId         String
  userBId         String
  relatedPostId   String?
  relatedRequestId String?
  relatedDealRoomId String?
  archivedByA     Boolean   @default(false)
  archivedByB     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  userA           User      @relation("ConversationA", fields: [userAId], references: [id], onDelete: Cascade)
  userB           User      @relation("ConversationB", fields: [userBId], references: [id], onDelete: Cascade)
  messages        Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  attachments    String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model DealRoom {
  id               String             @id @default(cuid())
  title            String
  businessType     String
  propertyType     String?
  location         String?
  estimatedPrice   Float?
  buyerClient      String?
  professionalName String?
  commissionAgreed Float?
  commissionPercent Float?
  commissionSplit  String?
  sharePercentage  Float?
  deadline         DateTime?
  participantIds   String?
  requiredDocs     String?
  observations     String?
  status           String             @default("LEAD")
  ownerId          String
  invitedUserId    String?
  propertyPostId   String?
  requestId        String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  owner            User               @relation("DealRoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  invitedUser      User?              @relation("DealRoomInvited", fields: [invitedUserId], references: [id], onDelete: SetNull)
  request          Request?           @relation(fields: [requestId], references: [id], onDelete: SetNull)
  messages         DealRoomMessage[]
  tasks            DealRoomTask[]
  documents        DealRoomDocument[]
  meetings         DealRoomMeeting[]
}

model DealRoomMessage {
  id         String   @id @default(cuid())
  dealRoomId String
  senderId   String
  body       String
  createdAt  DateTime @default(now())
  dealRoom   DealRoom @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model DealRoomTask {
  id         String   @id @default(cuid())
  dealRoomId String
  title      String
  done       Boolean  @default(false)
  dueDate    DateTime?
  assigneeId String?
  createdById String
  createdAt  DateTime @default(now())
  dealRoom   DealRoom @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  createdBy  User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model DealRoomDocument {
  id         String   @id @default(cuid())
  dealRoomId String
  title      String
  url        String
  uploadedAt DateTime @default(now())
  dealRoom   DealRoom @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
}

model DealRoomMeeting {
  id           String   @id @default(cuid())
  dealRoomId   String
  title        String
  type         String
  date         String
  time         String
  duration     Int?
  participants String?
  meetLink     String?
  description  String?
  status       String   @default("SCHEDULED")
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  dealRoom     DealRoom @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model Group {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  category    String
  createdAt   DateTime      @default(now())
  members     GroupMember[]
  posts       GroupPost[]
  messages    GroupMessage[]
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model GroupPost {
  id          String   @id @default(cuid())
  groupId     String
  authorId    String
  title       String
  description String
  createdAt   DateTime @default(now())
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  senderId  String
  body      String
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
